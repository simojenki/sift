#!/usr/bin/env python3
import argparse
import datetime
import hashlib
import shutil
import sqlite3
from dataclasses import dataclass
from pathlib import Path

DB_FILE = ".sift.db"


@dataclass
class SiftRecord:
    hash: str
    filename: str
    first_seen: str


def hash_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


class SiftRecords:
    def __init__(self, dest: Path) -> None:
        self._db_path = dest / DB_FILE
        self._conn: sqlite3.Connection | None = None

    def _get_conn(self) -> sqlite3.Connection:
        if self._conn is None:
            self._conn = sqlite3.connect(self._db_path)
            self._conn.execute("""
                CREATE TABLE IF NOT EXISTS hashes (
                    hash       TEXT PRIMARY KEY,
                    filename   TEXT NOT NULL,
                    first_seen TEXT NOT NULL
                )
            """)
            self._conn.commit()
        return self._conn

    def contains(self, hash: str) -> bool:
        if not self._db_path.exists():
            return False
        return self._get_conn().execute(
            "SELECT 1 FROM hashes WHERE hash = ?", (hash,)
        ).fetchone() is not None

    def insert(self, record: SiftRecord) -> None:
        conn = self._get_conn()
        conn.execute(
            "INSERT OR IGNORE INTO hashes (hash, filename, first_seen) VALUES (?, ?, ?)",
            (record.hash, record.filename, record.first_seen),
        )
        conn.commit()

    def close(self) -> None:
        if self._conn is not None:
            self._conn.close()
            self._conn = None

    def __enter__(self) -> "SiftRecords":
        return self

    def __exit__(self, *_: object) -> None:
        self.close()


def discover_files(src: Path) -> list[Path]:
    return [p for p in src.rglob("*") if p.is_file()]


def move_files(src: Path, dest: Path) -> None:
    with SiftRecords(dest) as store:
        for file in discover_files(src):
            relative = file.relative_to(src)
            target = dest / relative
            if target.exists():
                continue
            h = hash_file(file)
            if store.contains(h):
                continue
            target.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(file), str(target))
            store.insert(SiftRecord(
                hash=h,
                filename=file.name,
                first_seen=datetime.datetime.now(datetime.UTC).isoformat(),
            ))


def main():
    parser = argparse.ArgumentParser(description="Move files from src to dest, skipping existing files.")
    parser.add_argument("src", help="Source directory")
    parser.add_argument("dest", help="Destination directory")
    args = parser.parse_args()
    move_files(Path(args.src), Path(args.dest))


if __name__ == "__main__":
    main()
