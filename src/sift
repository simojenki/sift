#!/usr/bin/env python3
import argparse
import datetime
import hashlib
import shutil
import sqlite3
from collections.abc import Callable
from concurrent.futures import ThreadPoolExecutor, as_completed
from dataclasses import dataclass
from pathlib import Path

DB_FILE = ".sift.db"


@dataclass
class SiftRecord:
    hash: str
    filename: str
    first_seen: str


def hash_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


class SiftRecords:
    def __init__(self, dest: Path) -> None:
        self._db_path = dest / DB_FILE
        self._conn: sqlite3.Connection | None = None

    def _get_conn(self) -> sqlite3.Connection:
        if self._conn is None:
            self._conn = sqlite3.connect(self._db_path)
            self._conn.execute("""
                CREATE TABLE IF NOT EXISTS hashes (
                    hash       TEXT PRIMARY KEY,
                    filename   TEXT NOT NULL,
                    first_seen TEXT NOT NULL
                )
            """)
            self._conn.commit()
        return self._conn

    def get(self, hash: str) -> SiftRecord | None:
        if not self._db_path.exists():
            return None
        row = self._get_conn().execute(
            "SELECT hash, filename, first_seen FROM hashes WHERE hash = ?", (hash,)
        ).fetchone()
        return SiftRecord(hash=row[0], filename=row[1], first_seen=row[2]) if row else None

    def insert(self, record: SiftRecord) -> None:
        conn = self._get_conn()
        conn.execute(
            "INSERT OR IGNORE INTO hashes (hash, filename, first_seen) VALUES (?, ?, ?)",
            (record.hash, record.filename, record.first_seen),
        )
        conn.commit()

    def close(self) -> None:
        if self._conn is not None:
            self._conn.close()
            self._conn = None

    def __enter__(self) -> "SiftRecords":
        return self

    def __exit__(self, *_: object) -> None:
        self.close()


def discover_files(src: Path) -> list[Path]:
    return [p for p in src.rglob("*") if p.is_file()]


def move_files(src: Path, dest: Path, log: Callable[[str], None] = lambda _: None, workers: int = 1) -> None:
    with SiftRecords(dest) as store:
        candidates: list[tuple[Path, Path]] = []
        for file in discover_files(src):
            target = dest / file.relative_to(src)
            if target.exists():
                log(f"! {file.name}")
                continue
            candidates.append((file, target))

        with ThreadPoolExecutor(max_workers=workers) as executor:
            futures = {executor.submit(hash_file, file): (file, target)
                       for file, target in candidates}
            for future in as_completed(futures):
                file, target = futures[future]
                h = future.result()
                existing = store.get(h)
                if existing is not None:
                    log(f"!! {file.name} ({h} {existing.filename} @ {existing.first_seen})")
                    continue
                target.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(str(file), str(target))
                store.insert(SiftRecord(
                    hash=h,
                    filename=file.name,
                    first_seen=datetime.datetime.now(datetime.UTC).isoformat(),
                ))
                log(f"+ {file.name}")


def main():
    parser = argparse.ArgumentParser(description="Move files from src to dest, skipping existing files.")
    parser.add_argument("src", help="Source directory")
    parser.add_argument("dest", help="Destination directory")
    parser.add_argument("-v", action="store_true", help="Verbose output")
    parser.add_argument("-j", type=int, default=1, metavar="N", help="Number of hash workers (default: 1)")
    args = parser.parse_args()
    log = print if args.v else lambda _: None
    move_files(Path(args.src), Path(args.dest), log=log, workers=args.j)


if __name__ == "__main__":
    main()
