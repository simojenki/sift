#!/usr/bin/env python3
import argparse
import shutil
from pathlib import Path


def discover_files(src: Path) -> list[Path]:
    return [p for p in src.rglob("*") if p.is_file()]


def move_files(src: Path, dest: Path) -> None:
    for file in discover_files(src):
        relative = file.relative_to(src)
        target = dest / relative
        if target.exists():
            continue
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(str(file), str(target))


def main():
    parser = argparse.ArgumentParser(description="Move files from src to dest, skipping existing files.")
    parser.add_argument("src", help="Source directory")
    parser.add_argument("dest", help="Destination directory")
    args = parser.parse_args()
    move_files(Path(args.src), Path(args.dest))


if __name__ == "__main__":
    main()
